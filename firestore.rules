rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admins: acesso total via Firebase Admin SDK (server-side), regras bloqueiam client-side
    match /students/{studentId} {
      // Apenas o próprio aluno pode ler seu documento (via client SDK no portal)
      allow read: if request.auth != null && request.auth.uid == studentId;
      // Escrita apenas server-side (Admin SDK ignora rules)
      allow write: if false;

      match /workouts/{workoutId} {
        allow read: if request.auth != null && request.auth.uid == studentId;
        allow write: if false;
      }

      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == studentId;
        allow write: if false;
      }
    }
  }
}
